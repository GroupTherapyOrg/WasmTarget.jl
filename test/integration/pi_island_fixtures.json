        "extract_ok": true,
        "fn_src": "function (n::Int64,)\n    return if pieces(n) == (n * (n + 1)) / 2 + 1\n            (((\"<div class=\\\"markdown\\\"><p><em>Testing...</em></p>\\n<p><strong>For \" * string(n)) * \" cuts, you predict \") * string(pieces(n))) * \" pieces.</strong></p>\\n<div class=\\\"admonition correct\\\"><p class=\\\"admonition-title\\\">Got it!</p><p>Well done&#33;</p>\\n\\n</div>\\n\\n</div>\"\n        else\n            (((((\"<div class=\\\"markdown\\\"><p><em>Testing...</em></p>\\n<p><strong>For \" * string(n)) * \" cuts, you predict \") * string(pieces(n))) * \" pieces.</strong></p>\\n<div class=\\\"admonition danger\\\"><p class=\\\"admonition-title\\\">Keep working on it!</p><p>The answer should be \") * string(Int((n * (n + 1)) / 2 + 1))) * \".</p>\\n\\n</div>\\n\\n</div>\"\n        end\nend",
        "golden": [
          "\"<div class=\\\"markdown\\\"><p><em>Testing...</em></p>\\n<p><strong>For 25 cuts, you predict 25 pieces.</strong></p>\\n<div class=\\\"admonition danger\\\"><p class=\\\"admonition-title\\\">Keep working on it!</p><p>The answer should be 326.</p>\\n\\n</div>\\n\\n</div>\"",
          "\"<div class=\\\"markdown\\\"><p><em>Testing...</em></p>\\n<p><strong>For 0 cuts, you predict 0 pieces.</strong></p>\\n<div class=\\\"admonition danger\\\"><p class=\\\"admonition-title\\\">Keep working on it!</p><p>The answer should be 1.</p>\\n\\n</div>\\n\\n</div>\"",
          "\"<div class=\\\"markdown\\\"><p><em>Testing...</em></p>\\n<p><strong>For 50 cuts, you predict 50 pieces.</strong></p>\\n<div class=\\\"admonition danger\\\"><p class=\\\"admonition-title\\\">Keep working on it!</p><p>The answer should be 1276.</p>\\n\\n</div>\\n\\n</div>\""
        ],
